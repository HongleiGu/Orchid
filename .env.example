# ════════════════════════════════════════════════════════════════════════════
#  Orchid — environment config
#  Copy to .env and fill in your values.
# ════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=http://localhost:3000

# ── Ports (used by docker-compose) ──────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Frontend → Backend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Database ─────────────────────────────────────────────────────────────────
# Dev (SQLite, no Docker needed):
DATABASE_URL=sqlite+aiosqlite:///./agentapp.db
# Docker / production (overridden by docker-compose):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentapp

# ── Redis ────────────────────────────────────────────────────────────────────
# Leave blank for in-process mode (dev only, single worker)
REDIS_URL=
# Docker / production (overridden by docker-compose):
# REDIS_URL=redis://localhost:6379/0

# ── LLM routing ─────────────────────────────────────────────────────────────
LLM_DEFAULT_MODEL=openrouter/openai/gpt-4o-mini
LLM_FALLBACK_MODEL=

# ── LiteLLM tuning ──────────────────────────────────────────────────────────
LITELLM_DROP_PARAMS=true
LITELLM_REQUEST_TIMEOUT=120
LITELLM_MAX_RETRIES=3

# ── Provider API keys (set only what you use) ────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE=
GROQ_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_API_BASE=http://localhost:11434

# ── WeChat Official Account (公众号) ─────────────────────────────────────────
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ── Gmail OAuth (visit /api/v1/gmail/auth after setting these) ──────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ── Tools ────────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPAPI_API_KEY=
BRAVE_API_KEY=

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
SCHEDULER_MAX_CONCURRENT_RUNS=5
